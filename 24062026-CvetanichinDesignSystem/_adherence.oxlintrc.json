{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/forms/**",
              "components/sections/**",
              "ui_kits/cvetanichin-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Outfit))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Outfit."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:rose|outline|charcoal|soft)$/]",
        "message": "<Badge> variant must be one of 'rose' | 'outline' | 'charcoal' | 'soft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|arrow|block|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, arrow, block, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CTABlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:heading|price|priceDetail|ctaLabel|ctaHref|onCta|reassurances|layout|key|ref|className|style|children)$/]",
        "message": "<CTABlock> doesn't accept that prop. Declared props: heading, price, priceDetail, ctaLabel, ctaHref, onCta, reassurances, layout."
      },
      {
        "selector": "JSXOpeningElement[name.name='CTABlock'] > JSXAttribute[name.name='layout'] > Literal[value!=/^(?:split|stack)$/]",
        "message": "<CTABlock> layout must be one of 'split' | 'stack'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:gradient|rule|hair|on-dark)$/]",
        "message": "<Divider> variant must be one of 'gradient' | 'rule' | 'hair' | 'on-dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|as|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: tone, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:rose|rose-light|muted|on-dark)$/]",
        "message": "<Eyebrow> tone must be one of 'rose' | 'rose-light' | 'muted' | 'on-dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|title|description|variant|key|ref|className|style|children)$/]",
        "message": "<FeatureItem> doesn't accept that prop. Declared props: number, title, description, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureItem'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:numbered|step)$/]",
        "message": "<FeatureItem> variant must be one of 'numbered' | 'step'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|as|options|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, as, options."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:input|textarea|select)$/]",
        "message": "<Input> as must be one of 'input' | 'textarea' | 'select'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|description|price|priceNote|mark|serifTitle|hover|warm|footer|as|children|key|ref|className|style|children)$/]",
        "message": "<ProductCard> doesn't accept that prop. Declared props: eyebrow, title, description, price, priceNote, mark, serifTitle, hover, warm, footer, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:div|a|article)$/]",
        "message": "<ProductCard> as must be one of 'div' | 'a' | 'article'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Quote'] > JSXAttribute > JSXIdentifier[name!=/^(?:attribution|variant|mark|children|key|ref|className|style|children)$/]",
        "message": "<Quote> doesn't accept that prop. Declared props: attribution, variant, mark, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Quote'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:accent|plain|inset)$/]",
        "message": "<Quote> variant must be one of 'accent' | 'plain' | 'inset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
